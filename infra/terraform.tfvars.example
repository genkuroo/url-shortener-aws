# Copy this file to `terraform.tfvars` and adjust if you want non-default values.
# terraform.tfvars is gitignored (it can hold real/sensitive values); this
# .example template is the committed reference.

region  = "us-east-1"
project = "url-shortener"

# Phase 6 — where CloudWatch alarm notifications go. Required (no default).
# AWS emails a one-time confirmation link you must click before alerts arrive.
alert_email = "you@example.com"
