# Phase 4 — RDS Postgres (the data tier)
#
# A managed Postgres database living in the PRIVATE subnets, so it has no route
# to or from the internet. Only the Fargate task (via the db security group) can
# reach it on port 5432. AWS handles patching, backups, and the underlying host.

# A DB subnet group tells RDS which subnets it may place the database in. RDS
# requires at least two subnets in two AZs even for a single-AZ instance, so we
# hand it both private subnets.
resource "aws_db_subnet_group" "main" {
  name       = "${var.project}-db"
  subnet_ids = [for s in aws_subnet.private : s.id]

  tags = { Name = "${var.project}-db-subnet-group" }
}

resource "aws_db_instance" "main" {
  identifier     = "${var.project}-db"
  engine         = "postgres"
  engine_version = "16"
  instance_class = "db.t4g.micro" # Graviton, 12-month free tier

  # Storage. 20 GB gp3 is within the free-tier allowance.
  allocated_storage = 20
  storage_type      = "gp3"

  # Initial database + master credentials. The password is generated by
  # Terraform (see secrets.tf) and never written to disk in plaintext.
  db_name  = var.db_name
  username = var.db_username
  password = random_password.db.result

  # Networking: private subnets only, locked to the db security group, and
  # explicitly NOT publicly accessible.
  db_subnet_group_name   = aws_db_subnet_group.main.name
  vpc_security_group_ids = [aws_security_group.db.id]
  publicly_accessible    = false

  # Single-AZ keeps it free-tier; Multi-AZ would double the cost.
  multi_az = false

  # Tear-down friendly: no final snapshot, no backups to clean up, and changes
  # apply right away instead of waiting for a maintenance window. You would set
  # all of these the other way in production.
  skip_final_snapshot     = true
  backup_retention_period = 0
  deletion_protection     = false
  apply_immediately       = true

  tags = { Name = "${var.project}-db" }
}
